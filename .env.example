# Copy this file to .env.local for local dev (vercel dev reads it automatically).
# In production, set these in the Vercel dashboard instead:
# Project → Settings → Environment Variables

# Free key from https://console.groq.com (no credit card needed)
GROQ_API_KEY=

# Free credentials from https://register.fca.org.uk/Developer/s/
# (sign up, request API access — currently free, no SLA)
FCA_AUTH_EMAIL=
FCA_AUTH_KEY=
