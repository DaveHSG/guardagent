# Copy this file to .env.local for local dev (vercel dev reads it automatically).
# In production, set these in the Vercel dashboard instead:
# Project → Settings → Environment Variables

# Free key from https://console.groq.com (no credit card needed)
GROQ_API_KEY=

# Free credentials from https://register.fca.org.uk/Developer/s/
# (sign up, request API access — currently free, no SLA)
FCA_AUTH_EMAIL=
FCA_AUTH_KEY=

# Free from https://console.upstash.com — create a Redis database, then
# copy the REST URL and token from the database's REST API section.
# Free tier: 500K commands/month, 256MB storage, no credit card.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Free database for the audit trail: https://console.upstash.com
# Create a Redis database (free tier), then copy these from its dashboard
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
